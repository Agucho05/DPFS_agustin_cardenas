<!doctype html>
<html lang="es">
  <head>
    <!-- Incluimos el Head -->
    <%- include('../partials/head') %>
  </head>
  <body>
    <!-- Incluimos el Header -->
    <%- include('../partials/header') %>

    <main class="auth-wrapper">
      <section class="auth-card">
        <h2>Crear una cuenta</h2>

        <form action="#" method="GET">
          <div class="form-group">
            <label for="nombre">Nombre</label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              class="form-input"
              placeholder="Ej: Agustín"
              required
            />
          </div>

          <div class="form-group">
            <label for="apellido">Apellido</label>
            <input
              type="text"
              id="apellido"
              name="apellido"
              class="form-input"
              required
            />
          </div>

          <div class="form-group">
            <label for="email">Correo Electrónico</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              required
            />
          </div>

          <div class="form-group">
            <label for="password">Contraseña</label>
            <!-- Agregamos la clase 'error' para cumplir con la muestra de validación visual del sprint -->
            <input
              type="password"
              id="password"
              name="password"
              class="form-input error"
              value="123"
              required
            />
            <span class="error-message"
              >La contraseña debe tener al menos 8 caracteres.</span
            >
          </div>

          <button type="submit" class="btn-primary full-width">
            Registrarme
          </button>
        </form>

        <div class="auth-links">
          <!-- Actualizado para usar rutas de Express en lugar de archivos .html -->
          <p>¿Ya tienes cuenta? <a href="/login">Iniciar sesión</a></p>
        </div>
      </section>
    </main>

    <!-- Incluimos el Footer -->
    <%- include('../partials/footer') %>
  </body>
</html>
