<!doctype html>
<html lang="es">
  <head>
    <%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/header') %>

    <main class="auth-wrapper">
      <section class="auth-card">
        <h2>Crear una cuenta</h2>

        <form action="/registro" method="POST" enctype="multipart/form-data">
          
          <!-- CAMPO NOMBRE -->
          <div class="form-group">
            <label for="nombre">Nombre</label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              class="form-input"
              placeholder="Ej: Agustín"
              value="<%= locals.oldData ? oldData.nombre : '' %>"
            />
            <!-- Mensaje de error de Express Validator -->
            <% if (locals.errors && errors.nombre) { %>
              <p style="color: #d9534f; font-size: 0.85rem; margin-top: 0.3rem; margin-bottom: 0;"><%= errors.nombre.msg %></p>
            <% } %>
          </div>

          <!-- CAMPO APELLIDO -->
          <div class="form-group">
            <label for="apellido">Apellido</label>
            <input
              type="text"
              id="apellido"
              name="apellido"
              class="form-input"
              value="<%= locals.oldData ? oldData.apellido : '' %>"
            />
            <% if (locals.errors && errors.apellido) { %>
              <p style="color: #d9534f; font-size: 0.85rem; margin-top: 0.3rem; margin-bottom: 0;"><%= errors.apellido.msg %></p>
            <% } %>
          </div>

          <!-- CAMPO EMAIL -->
          <div class="form-group">
            <label for="email">Correo Electrónico</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              value="<%= locals.oldData ? oldData.email : '' %>"
            />
            <% if (locals.errors && errors.email) { %>
              <p style="color: #d9534f; font-size: 0.85rem; margin-top: 0.3rem; margin-bottom: 0;"><%= errors.email.msg %></p>
            <% } %>
          </div>

          <!-- CAMPO CONTRASEÑA -->
          <div class="form-group">
            <label for="password">Contraseña</label>
            <input
              type="password"
              id="password"
              name="password"
              class="form-input"
            />
            <!-- Por seguridad, las contraseñas no se devuelven en el value -->
            <% if (locals.errors && errors.password) { %>
              <p style="color: #d9534f; font-size: 0.85rem; margin-top: 0.3rem; margin-bottom: 0;"><%= errors.password.msg %></p>
            <% } %>
          </div>

          <!-- CAMPO AVATAR -->
          <div class="form-group">
            <label for="avatar">Foto de Perfil</label>
            <input
              type="file"
              id="avatar"
              name="avatar"
              class="form-input"
              style="padding: 0.5rem 0; color: #ccc"
            />
            <% if (locals.errors && errors.avatar) { %>
              <p style="color: #d9534f; font-size: 0.85rem; margin-top: 0.3rem; margin-bottom: 0;"><%= errors.avatar.msg %></p>
            <% } %>
          </div>

          <button
            type="submit"
            class="btn-primary full-width"
            style="margin-top: 1rem"
          >
            Registrarme
          </button>
        </form>

        <div class="auth-links">
          <p>¿Ya tienes cuenta? <a href="/login">Iniciar sesión</a></p>
        </div>
      </section>
    </main>

    <%- include('../partials/footer') %>
    
    <!-- Conectamos la validación Front-end -->
    <script src="/js/registerValidation.js"></script>
  </body>
</html>