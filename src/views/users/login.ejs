<!doctype html>
<html lang="es">
  <head>
    <%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/header') %>

    <main class="auth-wrapper">
      <section class="auth-card">
        <h2>Iniciar Sesión</h2>

        <form action="/login" method="POST">
          
          <!-- CAMPO EMAIL -->
          <div class="form-group">
            <label for="email">Correo Electrónico</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              value="<%= locals.oldData ? oldData.email : '' %>"
            />
            <!-- Mensaje de error para el email -->
            <% if (locals.errors && errors.email) { %>
              <p style="color: #d9534f; font-size: 0.85rem; margin-top: 0.3rem; margin-bottom: 0;"><%= errors.email.msg %></p>
            <% } %>
          </div>

          <!-- CAMPO CONTRASEÑA -->
          <div class="form-group">
            <label for="password">Contraseña</label>
            <input
              type="password"
              id="password"
              name="password"
              class="form-input"
            />
            <!-- Mensaje de error para la contraseña -->
            <% if (locals.errors && errors.password) { %>
              <p style="color: #d9534f; font-size: 0.85rem; margin-top: 0.3rem; margin-bottom: 0;"><%= errors.password.msg %></p>
            <% } %>
          </div>

          <div class="form-options">
            <label class="remember-me">
              <input type="checkbox" name="remember" /> Recordarme
            </label>
            <a href="#" class="forgot-password">¿Olvidaste tu contraseña?</a>
          </div>

          <button type="submit" class="btn-primary full-width">Ingresar</button>
        </form>

        <div class="auth-links">
          <p>¿No tienes cuenta? <a href="/registro">Crear una cuenta</a></p>
        </div>
      </section>
    </main>

    <%- include('../partials/footer') %>
    
    <!-- Conectamos la validación Front-end -->
    <script src="/js/loginValidation.js"></script>
  </body>
</html>