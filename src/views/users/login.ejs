<!doctype html>
<html lang="es">
  <head>
    <!-- Incluimos el Head -->
    <%- include('../partials/head') %>
  </head>
  <body>
    <!-- Incluimos el Header -->
    <%- include('../partials/header') %>

    <main class="auth-wrapper">
      <section class="auth-card">
        <h2>Iniciar Sesión</h2>

        <form action="#" method="GET">
          <div class="form-group">
            <label for="email">Correo Electrónico</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              required
            />
          </div>

          <div class="form-group">
            <label for="password">Contraseña</label>
            <input
              type="password"
              id="password"
              name="password"
              class="form-input"
              required
            />
          </div>

          <!-- Contenedor para "Recordarme" y "Olvidé mi contraseña" -->
          <div class="form-options">
            <label class="remember-me">
              <input type="checkbox" name="remember" /> Recordarme
            </label>
            <a href="#" class="forgot-password">¿Olvidaste tu contraseña?</a>
          </div>

          <button type="submit" class="btn-primary full-width">Ingresar</button>
        </form>

        <div class="auth-links">
          <!-- Actualizado para usar rutas de Express en lugar de archivos .html -->
          <p>¿No tienes cuenta? <a href="/registro">Crear una cuenta</a></p>
        </div>
      </section>
    </main>

    <!-- Incluimos el Footer -->
    <%- include('../partials/footer') %>
  </body>
</html>
