<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('partials/head') %>
  </head>
  <body>
    <%- include('partials/header') %>

    <section class="hero-banner">
      <h1>Componentes de Alto Rendimiento</h1>
      <button class="btn-primary">Ver ofertas</button>
    </section>

    <main class="products-section">
      <h2>Productos Destacados</h2>
      
      <div class="product-grid">
        <% products.forEach(function(producto) { %>
          
          <article class="product-card">
            <!-- Renderizamos la imagen real -->
            <div class="product-image-container" style="text-align: center; margin-bottom: 1rem;">
              <img src="/images/<%= producto.image %>" alt="<%= producto.name %>" style="max-width: 100%; border-radius: 8px; height: 200px; object-fit: cover;">
            </div>
            
            <h3><%= producto.name %></h3>
            <p class="price">$<%= producto.price %></p>
            
            <a href="/products/<%= producto.id %>" style="text-decoration: none;">
                <button class="btn-secondary" style="width: 100%;">Ver detalle</button>
            </a>
          </article>
          
        <% }); %>
      </div>

    </main>

    <%- include('partials/footer') %>
  </body>
</html>