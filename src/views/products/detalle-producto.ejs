<!doctype html>
<html lang="es">
  <head>
    <%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/header') %>

    <main class="product-detail-container">
      <div class="product-image-large">Imagen de <%= product.name %></div>

      <section class="product-info">
        <h1><%= product.name %></h1>
        <p class="price-large">$<%= product.price %></p>

        <div class="specs">
          <h3>Descripción:</h3>
          <p><%= product.description %></p>
          
          <h4 style="margin-top: 1rem;">Colores disponibles:</h4>
          <ul>
            <% product.colors.forEach(function(color) { %>
              <li><%= color %></li>
            <% }); %>
          </ul>
        </div>

        <div class="purchase-actions">
          <label for="quantity">Cantidad:</label>
          <input type="number" id="quantity" name="quantity" min="1" value="1" class="quantity-input" />
          <button class="btn-primary full-width">Agregar al carrito</button>
        </div>

        <div class="admin-actions" style="margin-top: 2rem; display: flex; gap: 1rem;">
          <a href="/products/<%= product.id %>/edit" class="btn-secondary" style="flex: 1; text-align: center; text-decoration: none;">
            Editar Producto
          </a>
          
          <form action="/products/<%= product.id %>?_method=DELETE" method="POST" style="flex: 1;">
            <button type="submit" class="btn-primary" style="width: 100%; background-color: #d9534f; border-color: #d9534f;">
              Eliminar Producto
            </button>
          </form>
        </div>

      </section>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>