<!doctype html>
<html lang="es">
  <head>
    <%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/header') %>

    <main class="auth-wrapper">
      <section class="auth-card" style="max-width: 600px">
        <h2>Cargar Nuevo Producto</h2>

        <!-- IMPORTANTE: Agregado enctype para que Multer pueda procesar la imagen -->
        <form action="/products" method="POST" enctype="multipart/form-data">
          <div class="form-group">
            <label for="name">Nombre del producto</label>
            <input type="text" id="name" name="name" class="form-input" placeholder="Ej: Mouse Logitech G Pro" required />
          </div>

          <div class="form-group">
            <label for="price">Precio</label>
            <input type="number" id="price" name="price" class="form-input" required />
          </div>

          <div class="form-group">
            <label for="category_id">Categoría</label>
            <select id="category_id" name="category_id" class="form-input" style="background-color: #222; color: white; border: 1px solid #444;" required>
              <option value="" disabled selected>Seleccioná una categoría</option>
              <!-- Iteramos las categorías que vienen de la Base de Datos -->
              <% categories.forEach(category => { %>
                <option value="<%= category.id %>"><%= category.name %></option>
              <% }); %>
            </select>
          </div>

          <div class="form-group">
            <label for="description">Descripción</label>
            <textarea id="description" name="description" class="form-input" rows="4" required></textarea>
          </div>

          <div class="form-group">
            <label for="image">Imagen del producto</label>
            <input type="file" id="image" name="image" style="color: #ccc; margin-top: 0.5rem" />
          </div>

          <button type="submit" class="btn-primary full-width" style="margin-top: 1rem">
            Guardar Producto
          </button>
        </form>
      </section>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>